{
  "manifest_version": 3,
  "name": "Keryx SMS Relay",
  "version": "1.0.0",
  "description": "Intercepts Google Messages for Web conversations and relays them to your Keryx life OS in real time.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://messages.google.com/*",
    "https://*.replit.dev/*",
    "https://*.replit.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://messages.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Keryx SMS Relay"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
