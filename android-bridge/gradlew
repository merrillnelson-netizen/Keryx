# Gradle start up script for POSIX generated by "Gradle init".

die () {
    echo
    echo "$*"
    echo
    exit 1
}

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH."
fi

# Increase the maximum file descriptors if we can.
MAX_FD=maximum
ulimit -n "$MAX_FD" 2>/dev/null && true

APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")

DIRNAME=$(cd "$(dirname "$0")" && pwd)
APP_HOME=$DIRNAME

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options.
# NOTE: Do not wrap options in extra quotes here — eval set handles word-splitting correctly.
DEFAULT_JVM_OPTS="-Xmx64m -Xms64m"

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Use eval/set to correctly word-split and pass JVM options, classpath, and main class.
# This avoids the classic shell quoting bug where literal quote characters in
# DEFAULT_JVM_OPTS end up passed to java as part of the class name.
eval set -- \
    $DEFAULT_JVM_OPTS \
    $JAVA_OPTS \
    $GRADLE_OPTS \
    "-Dorg.gradle.appname=$APP_BASE_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"

exec "$JAVACMD" "$@"
